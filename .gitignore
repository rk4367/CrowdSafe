# ============================================================
# CrowdSafe — Production .gitignore
# ============================================================

# ────────────────────────────────────────────────────────────
# Environment / Secrets  (NEVER commit these)
# ────────────────────────────────────────────────────────────
.env
.env.*
!.env.example

# ────────────────────────────────────────────────────────────
# Firebase / Google Cloud credentials
# ────────────────────────────────────────────────────────────
firebase-credentials.json
firebase-adminsdk*.json
*-credentials.json
serviceAccountKey.json
*.json.key
google-services.json
GoogleService-Info.plist

# ────────────────────────────────────────────────────────────
# Python
# ────────────────────────────────────────────────────────────
venv/
env/
ENV/
.venv/
**/venv/
**/env/
**/.venv/
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
*.egg-info/
*.egg
dist/
build/
.pytest_cache/
.coverage
htmlcov/
.mypy_cache/
.ruff_cache/

# ────────────────────────────────────────────────────────────
# Node / Frontend
# ────────────────────────────────────────────────────────────
node_modules/
frontend/dist/
frontend/build/
.npm
.eslintcache
.parcelcache

# ────────────────────────────────────────────────────────────
# ML / AI Model files  (large binaries — manage with Git LFS or DVC)
# ────────────────────────────────────────────────────────────
*.pth
*.pt
*.onnx
*.h5
*.pb
*.tflite
*.weights
*.pkl
*.joblib
backend/data/

# ────────────────────────────────────────────────────────────
# Uploads (user-generated content — never commit)
# ────────────────────────────────────────────────────────────
backend/uploads/
uploads/

# ────────────────────────────────────────────────────────────
# Logs
# ────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ────────────────────────────────────────────────────────────
# IDE / Editor
# ────────────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo
*~

# ────────────────────────────────────────────────────────────
# OS artifacts
# ────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# ────────────────────────────────────────────────────────────
# Temporary / Cache
# ────────────────────────────────────────────────────────────
*.tmp
*.temp
*.cache
.cache/
